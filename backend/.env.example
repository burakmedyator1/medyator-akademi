JWT_SECRET=replace-with-a-long-random-string
NODE_ENV=production
PORT=4000

# Only used by `npm run seed` to create the initial admin account.
# Set these before running seed in production — never commit real values.
ADMIN_EMAIL=admin@medyatorakademi.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Optional: SMTP credentials for the "welcome" email sent on student registration.
# If SMTP_HOST is unset, email sending is silently skipped (logged as a warning).
# A Google Workspace address can be used here with an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-address@yourdomain.com
SMTP_PASS=replace-with-an-app-password
MAIL_FROM=Medyator Akademi <no-reply@yourdomain.com>

# Optional: iyzico payment credentials for paid course checkout.
# If IYZICO_API_KEY/IYZICO_SECRET_KEY are unset, purchase is disabled and shows
# a "not ready yet" notice instead of erroring. Get sandbox keys for free at
# https://merchant.iyzipay.com (test first, then switch to production keys +
# IYZICO_BASE_URL=https://api.iyzipay.com once your merchant account is approved).
IYZICO_API_KEY=replace-with-your-api-key
IYZICO_SECRET_KEY=replace-with-your-secret-key
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com
# Public URL of this deployed app, used to build iyzico's callback/redirect URLs.
# Only needed if it can't be inferred from the request (e.g. behind some proxies).
APP_BASE_URL=https://medyagency.co
