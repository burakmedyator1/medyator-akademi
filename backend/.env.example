JWT_SECRET=replace-with-a-long-random-string
NODE_ENV=production
PORT=4000

# Only used by `npm run seed` to create the initial admin account.
# Set these before running seed in production — never commit real values.
ADMIN_EMAIL=admin@medyatorakademi.com
ADMIN_PASSWORD=replace-with-a-strong-password

# Optional: SMTP credentials for the "welcome" email sent on student registration.
# If SMTP_HOST is unset, email sending is silently skipped (logged as a warning).
# A Google Workspace address can be used here with an App Password.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-address@yourdomain.com
SMTP_PASS=replace-with-an-app-password
MAIL_FROM=Medyator Akademi <no-reply@yourdomain.com>
